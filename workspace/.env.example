# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# CrowdWorks Credentials
CROWDWORKS_EMAIL=your-email@example.com
CROWDWORKS_PASSWORD=your-password
CROWDWORKS_AUTO_SEND=false  # Set to 'true' to auto-send replies (review mode if false)

# Lancers Credentials
LANCERS_EMAIL=your-email@example.com
LANCERS_PASSWORD=your-password

# Forkwell Credentials (optional)
FORKWELL_EMAIL=your-email@example.com
FORKWELL_PASSWORD=your-password

# Daijob Credentials (for existing bot)
DAIJOB_EMAIL=your-email@example.com
DAIJOB_PASSWORD=your-password
